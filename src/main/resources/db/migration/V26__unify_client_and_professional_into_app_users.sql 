CREATE TABLE app_users_new (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,

    name VARCHAR(100) NOT NULL,
    email VARCHAR(120) UNIQUE NOT NULL,
    phone VARCHAR(20),
    location VARCHAR(100),
    professional_title VARCHAR(100),
    password VARCHAR(255),
    profile_picture VARCHAR(255),
    email_verified BOOLEAN NOT NULL DEFAULT FALSE,
    provider VARCHAR(20),
    provider_id VARCHAR(100),

    active_role VARCHAR(20) NOT NULL DEFAULT 'CLIENT',
    last_role_switch_at DATETIME,

    profession_type VARCHAR(50),
    reputation_score DOUBLE DEFAULT 0.0,
    total_ratings INT DEFAULT 0,
    monthly_workplace_changes INT DEFAULT 0,
    last_workplace_change_date DATE,
    searchable BOOLEAN DEFAULT FALSE,

    created_at DATETIME NOT NULL,
    updated_at DATETIME NOT NULL,

    INDEX idx_email (email),
    INDEX idx_active_role (active_role),
    INDEX idx_profession_type (profession_type)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

INSERT INTO app_users_new (
    id, name, email, phone, location, professional_title, password,
    profile_picture, email_verified, provider, provider_id,
    active_role, last_role_switch_at,
    profession_type, reputation_score, total_ratings,
    monthly_workplace_changes, last_workplace_change_date, searchable,
    created_at, updated_at
)
SELECT
    u.id,
    u.name,
    u.email,
    u.phone,
    u.location,
    u.professional_title,
    u.password,
    u.profile_picture,
    u.email_verified,
    u.provider,
    u.provider_id,
    COALESCE(u.active_role, 'PROFESSIONAL') as active_role,
    u.last_role_switch_at,
    p.profession_type,
    COALESCE(p.reputation_score, 0.0) as reputation_score,
    COALESCE(p.total_ratings, 0) as total_ratings,
    COALESCE(p.monthly_workplace_changes, 0) as monthly_workplace_changes,
    p.last_workplace_change_date,
    COALESCE(p.searchable, FALSE) as searchable,
    u.created_at,
    u.updated_at
FROM app_users u
INNER JOIN professionals p ON u.id = p.id
WHERE u.user_type = 'PROFESSIONAL';

INSERT INTO app_users_new (
    id, name, email, phone, location, professional_title, password,
    profile_picture, email_verified, provider, provider_id,
    active_role, last_role_switch_at,
    created_at, updated_at
)
SELECT
    u.id,
    u.name,
    u.email,
    u.phone,
    u.location,
    u.professional_title,
    u.password,
    u.profile_picture,
    u.email_verified,
    u.provider,
    u.provider_id,
    COALESCE(u.active_role, 'CLIENT') as active_role,
    u.last_role_switch_at,
    u.created_at,
    u.updated_at
FROM app_users u
INNER JOIN clients c ON u.id = c.id
WHERE u.user_type = 'CLIENT';

